{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "emergency-route": {
        "ClusterId": "emergency-cluster",
        "Match": {
          "Path": "/emergency/{**catch-all}"
        }
      },
      "dashboard-route": {
        "ClusterId": "dashboard-cluster",
        "Match": {
          "Path": "/dashboard/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/dashboard" }
        ]
      },
      "hub-route": {
        "ClusterId": "dashboard-cluster",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "emergency-cluster": {
        "Destinations": {
          "emergency-api": {
            "Address": "http://emergency-api"
          }
        }
      },
      "dashboard-cluster": {
        "Destinations": {
          "dashboard-service": {
            "Address": "http://dashboard"
          }
        }
      }
    }
  }
}
